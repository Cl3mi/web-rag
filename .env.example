# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=web_rag_lab
DATABASE_USER=rag_user
DATABASE_PASSWORD=rag_password
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=10

# ─── LLM Provider Switch ──────────────────────────────────────────────────────
# Change this one value to switch providers. Everything else stays as-is.
# Allowed values: ollama | openai | openrouter
LLM_PROVIDER=ollama

# Optional global overrides — if set, these override the active provider's model.
# Leave commented out to use the provider-specific models below.
# LLM_MODEL=
# LLM_JUDGE_MODEL=

# ─── Ollama (LLM_PROVIDER=ollama) ────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_JUDGE_MODEL=qwen2.5:7b

# ─── OpenAI (LLM_PROVIDER=openai) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # only needed for custom endpoints

# ─── OpenRouter (LLM_PROVIDER=openrouter) ────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_JUDGE_MODEL=mistralai/mistral-7b-instruct
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # only needed for custom endpoints

# ─── Embedding Model ──────────────────────────────────────────────────────────
# Independent of LLM_PROVIDER — OpenRouter has no embeddings API, so always pick
# local or openai here regardless of which LLM provider is active.
# Allowed values: local | openai
EMBEDDING_PROVIDER=local

# Vector dimension — MUST match the active embedding model.
# Changing this requires: bun run db:generate && bun run db:push + full reindex.
#   local  (Xenova/bge-m3):           1024  ← current default
#   openai (text-embedding-3-small):  1536
#   openai (text-embedding-ada-002):  1536
EMBEDDING_DIMENSION=1024

# ─── Local embeddings (EMBEDDING_PROVIDER=local) ─────────────────────────────
LOCAL_EMBEDDING_MODEL=Xenova/bge-m3

# ─── OpenAI embeddings (EMBEDDING_PROVIDER=openai) ───────────────────────────
# Uses the same OPENAI_API_KEY defined above.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
